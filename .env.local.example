# Copy this file to .env.local and fill in your values.
# .env.local is gitignored and will NOT be committed to GitHub.

# Password that collaborators use to access the site
SITE_PASSWORD=your-chosen-password-here

# From your Supabase project dashboard → Settings → API
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# From your Resend dashboard → API Keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Your email address — comment notifications will be sent here
NOTIFICATION_EMAIL=your-email@example.com
